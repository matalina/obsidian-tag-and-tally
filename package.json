{
  "name": "obsidian-tag-and-tally",
  "version": "0.1.36",
  "description": "Run Tag and Tally tabletop RPG sessions in your vault — dice resolution, an in-vault rulebook, NPC generator, random tables, and decks.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "typecheck": "vue-tsc --noEmit",
    "push": "bash scripts/push-to-vault.sh",
    "check": "node scripts/check.mjs",
    "publish": "bash scripts/publish.sh"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "tag-and-tally",
    "ttrpg"
  ],
  "author": "Alicia Wilkerson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/matalina/obsidian-tag-and-tally.git"
  },
  "bugs": {
    "url": "https://github.com/matalina/obsidian-tag-and-tally/issues"
  },
  "homepage": "https://github.com/matalina/obsidian-tag-and-tally#readme",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "obsidian": "1.4.11",
    "tslib": "2.3.1",
    "typescript": "~5.6.0",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.0"
  },
  "dependencies": {
    "@codemirror/language": "^6.12.1",
    "@dice-roller/rpg-dice-roller": "^5.5.1",
    "fuse.js": "^7.1.0",
    "lucide-vue-next": "^0.460.0",
    "markdown-it": "^14.1.1",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-obsidian-callouts": "^0.3.3",
    "open-props": "^1.7.23",
    "pinia": "^2.2.6",
    "vue": "^3.5.13",
    "vue-router": "^4.4.0"
  }
}
